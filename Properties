function PropertiesModule.UpdateProperties(_, p385)
	-- upvalues: (copy) propertiesMenu, (copy) logicPropertiesMenu, (copy) logicTypeHandlers
	propertiesMenu.Parts.Visible = false
	propertiesMenu.Parent.Builder.Visible = false
	propertiesMenu.Parent.Character.Visible = false
	if p385.Parent == workspace.Logic or p385.Name == "Dest" then
		propertiesMenu.Properties2.Visible = true
		logicPropertiesMenu.Visible = false
		propertiesMenu.Properties2.Input.Text = p385:GetAttribute("I") or ""
		propertiesMenu.Properties2.Output.Text = p385:GetAttribute("O") or ""
		for _, v386 in propertiesMenu.Properties2:GetChildren() do
			if not v386:IsA("UIListLayout") then
				if v386.Name == "Input" or (v386.Name == "Output" or v386.Name == "Delete") then
					v386.Visible = true
				else
					v386:Destroy()
				end
			end
		end
		logicPropertiesMenu.Properties.Visible = false
		logicPropertiesMenu.Properties2.Visible = true
		if logicTypeHandlers[p385.Name] then
			logicTypeHandlers[p385.Name](p385)
			return
		end
	else
		propertiesMenu.Properties.Visible = true
		logicPropertiesMenu.Visible = true
		logicPropertiesMenu.Properties.Visible = true
		logicPropertiesMenu.Properties2.Visible = false
		logicPropertiesMenu.Properties.Transparent.Visible = true
		logicPropertiesMenu.Properties.Material.Visible = true
		local v387 = logicPropertiesMenu.Properties.Color
		local v388 = p385.Color.R * 255
		local v389 = math.round(v388)
		local v390 = p385.Color.G * 255
		local v391 = math.round(v390)
		local v392 = p385.Color.B * 255
		v387.Text = v389 .. ", " .. v391 .. ", " .. math.round(v392)
		local v393 = logicPropertiesMenu.Properties.Transparent
		local v394 = p385.Transparency
		v393.Text = tostring(v394)
		propertiesMenu.Properties.CanCollide.BackgroundColor3 = p385.CanCollide == true and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(0, 60, 90)
		propertiesMenu.Properties.CastShadow.BackgroundColor3 = p385.CastShadow == true and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(0, 60, 90)
		propertiesMenu.Properties.Breakable.BackgroundColor3 = p385.Parent == workspace.Map.Destructible.Buildable == true and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(0, 60, 90)
		if p385:IsA("SpawnLocation") then
			propertiesMenu.Properties.Neutral.Visible = true
			propertiesMenu.Properties.Neutral.BackgroundColor3 = p385.Neutral == true and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(0, 60, 90)
			return
		end
		propertiesMenu.Properties.Neutral.Visible = false
	end
