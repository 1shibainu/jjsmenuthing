function SelectionHandler.FindSelection(_)
	local rotationCFrame = CFrame.new().Rotation
	if not _G.GlobalAxis then
		local firstPart = SelectionHandler:FirstSelected()
		if not firstPart then
			return
		end
		rotationCFrame = firstPart.CFrame.Rotation
	end

	local boundsCFrame, boundsSize = SelectionHandler:GetBoundingBox(SelectionHandler.Selected, rotationCFrame)
	selectionBox.Size = boundsSize
	selectionBox.CFrame = boundsCFrame

	-- Sync selection highlight borders
	local alreadyHighlighted = {}
	for _, border in selectionBox.Model:GetChildren() do
		if SelectionHandler.Selected[border.Adornee] then
			alreadyHighlighted[border.Adornee] = true
		else
			border:Destroy()
		end
	end
	for part, _ in SelectionHandler.Selected do
		if not alreadyHighlighted[part] then
			local border = script.Border:Clone()
			border.Adornee = part
			border.Parent = selectionBox.Model
		end
	end
end

function SelectionHandler.DeselectPart(_, part)
	if SelectionHandler.Selected[part] then
		SelectionHandler.Selected[part]:Disconnect()
	end
	SelectionHandler.Selected[part] = nil

	if #SelectionHandler.Selected <= 0 then
		propertiesMenu.Properties.Visible = false
		propertiesMenu.Properties2.Visible = false
		propertiesMenu.DeleteMulti.Visible = false
		propertiesMenu.Parts.Visible = true
		logicPropertiesMenu.Visible = false
		propertiesMenu.Parent.Builder.Visible = false
		propertiesMenu.Parent.Character.Visible = false
		selectionBox.Parent = nil
	else
		SelectionHandler:FindSelection()
	end
end

-- Maps special part class names to their canonical type name for property panel filtering
local partTypeAliases = {
	["SpawnLocation"] = "Part",
	["Truss"] = "Part",
	["Wedge"] = "Part"
}

function SelectionHandler.SelectPart(self, part)
	local ancestryConnection = part.AncestryChanged:Connect(function()
		if part.Parent == nil then
			SelectionHandler:DeselectPart(part)
		end
	end)

	if SelectionHandler.Selected[part] then
		SelectionHandler.Selected[part]:Disconnect()
	end
	SelectionHandler.Selected[part] = ancestryConnection
	SelectionHandler:FindSelection()

	selectionBox.Parent = script.Parent.Parent
	require(script.Parent.Properties):UpdateProperties(part)
	propertiesMenu.DeleteMulti.Visible = false

	local selectedList = self:SendSelected()
	local firstType = nil
	for _, selectedPart in selectedList do
		local partType = partTypeAliases[selectedPart.Name] or selectedPart.Name
		firstType = firstType or partType
		if not selectedPart:IsA("SpawnLocation") then
			propertiesMenu.Properties.Neutral.Visible = false
		end
		if partType ~= firstType then
			propertiesMenu.Properties2.Visible = false
			propertiesMenu.Properties.Visible = false
			propertiesMenu.DeleteMulti.Visible = true
			logicPropertiesMenu.Visible = false
			return
		end
	end
end

function SelectionHandler.CopyPart(_)
	copy = SelectionHandler:SendSelected()
	if #copy > 0 then
		buildEvent:FireServer("Copy", copy)
	end
end

function SelectionHandler.PastePart(_)
	if #copy > 0 then
		for part, _ in SelectionHandler.Selected do
			SelectionHandler:DeselectPart(part)
		end
		buildEvent:FireServer("Paste")
	end
end

return SelectionHandler
