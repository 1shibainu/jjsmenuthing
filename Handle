function SelectionHandler.GetBoundingBox(_, parts, referenceCFrame)
	local cf = referenceCFrame or CFrame.identity
	local maxZ = (-1 / 0)
	local minX = (1 / 0)
	local minY = (1 / 0)
	local minZ = (1 / 0)
	local maxX = (-1 / 0)
	local maxY = (-1 / 0)

	for part, _ in pairs(parts) do
		local size = part.Size
		local sX = size.X
		local sY = size.Y
		local sZ = size.Z
		local r00, r01, r02, r10, r11, r12, r20, r21, r22, tX, tY, tZ =
			cf:ToObjectSpace(part.CFrame):GetComponents()

		local extentX = (math.abs(r00) * sX + math.abs(r01) * sY + math.abs(r02) * sZ) * 0.5
		local extentY = (math.abs(r10) * sX + math.abs(r11) * sY + math.abs(r12) * sZ) * 0.5
		local extentZ = (math.abs(r20) * sX + math.abs(r21) * sY + math.abs(r22) * sZ) * 0.5

		if tX - extentX < minX then minX = tX - extentX end
		if tY - extentY < minY then minY = tY - extentY end
		if tZ - extentZ < minZ then minZ = tZ - extentZ end
		if maxX < tX + extentX then maxX = tX + extentX end
		if maxY < tY + extentY then maxY = tY + extentY end
		if maxZ < tZ + extentZ then maxZ = tZ + extentZ end
	end

	local boundsMin = Vector3.new(minX, minY, minZ)
	local boundsMax = Vector3.new(maxX, maxY, maxZ)
	return cf + cf:PointToWorldSpace((boundsMax + boundsMin) * 0.5), boundsMax - boundsMin
end

function SelectionHandler.SendSelected(_)
	local selectedList = {}
	for part, _ in SelectionHandler.Selected do
		table.insert(selectedList, part)
	end
	return selectedList
end

