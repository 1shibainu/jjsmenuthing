-- Sets the visual toggle state (green = on, red = off) for a toggle UI element
local function setToggleVisual(toggleFrame, isEnabled)
	if isEnabled == true then
		toggleFrame.Toggle.BackgroundColor3 = Color3.fromRGB(85, 255, 0)
		toggleFrame.Toggle.Side.BackgroundColor3 = Color3.fromRGB(169, 255, 189)
		toggleFrame.Toggle.Side.Position = UDim2.new(0, 0, 0, 0)
	else
		toggleFrame.Toggle.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
		toggleFrame.Toggle.Side.BackgroundColor3 = Color3.fromRGB(85, 0, 0)
		toggleFrame.Toggle.Side.Position = UDim2.new(0.5, 0, 0, 0)
	end
end

-- Performs a deep clone of a table (recursively copies nested tables)
local function deepClone(tbl)
	local clone = table.clone(tbl)
	for key, value in tbl do
		if type(value) == "table" then
			clone[key] = deepClone(value)
		end
	end
	return clone
end

local characterEditorPanel = script.Parent.Parent.Character

-- Returns the timeline button corresponding to a given layout order index (defaults to selectedSkillIndex)
local function getTimelineButtonByIndex(index)
	local result = nil
	for _, button in characterEditorPanel.Timeline.Timeline:GetChildren() do
		if button:IsA("TextButton") and button.LayoutOrder == (index or selectedSkillIndex) then
			return button
		end
	end
	return result
end

function CharacterEditor.updateSkillData(_, encodedData)
	skillEntries[selectedSkillIndex].DATA = encodedData
	local jsonData = httpService:JSONEncode(skillEntries)
	buildEvent:FireServer("LogicProp", selectionHandler:SendSelected(), "Dict", jsonData)
end

-- Refreshes the properties panel for the currently selected skill slot
local function refreshPropertiesPanel()
	-- Clear old property UI elements
	for _, child in characterEditorPanel.Timeline.Properties:GetChildren() do
		if not child:IsA("UIListLayout") then
			child:Destroy()
		end
	end

	if selectedSkillIndex and skillEntries[selectedSkillIndex] then
		characterEditorPanel.Timeline.Properties.Visible = true
		characterEditorPanel.Timeline.Items.Visible = false
		characterEditorPanel.Toolbar.Visible = true
		characterEditorPanel.Toolbar2.Visible = false

		-- Highlight selected timeline button
		for _, button in characterEditorPanel.Timeline.Timeline:GetChildren() do
			if button:IsA("TextButton") then
				if button.LayoutOrder == selectedSkillIndex then
					button.BorderColor3 = Color3.fromRGB(85, 255, 255)
				else
					button.BorderColor3 = Color3.fromRGB(0, 0, 0)
				end
			end
		end

		local selectedButton = getTimelineButtonByIndex()
		local skillTypeLabel = characterEditorPanel.Timeline.Items[selectedButton.Name].Text
		local skillData = skillEntries[selectedSkillIndex]

		-- Build property inputs based on skill type schema
		for fieldOrder, fieldDef in skillFieldSchema[skillData.K_NAME] do
			local fieldName = fieldDef[1]
			local inputType = fieldDef[2]

			if inputType == 1 then
				-- Boolean toggle
				local boolOption = characterGui.Preset.OptionBool:Clone()
				boolOption.Option.Text = fieldName
				boolOption.LayoutOrder = fieldOrder
				setToggleVisual(boolOption, skillData[fieldName] == true)
				boolOption.Parent = characterEditorPanel.Timeline.Properties
				boolOption.Toggle.Side.MouseButton1Down:Connect(function()
					skillData[fieldName] = skillData[fieldName] ~= true
					setToggleVisual(boolOption, skillData[fieldName] == true)
					local btn = selectedButton
					local label = skillTypeLabel
					btn.Text = "[" .. tostring(skillData.NAME) .. "] " .. label
					local jsonEncoded = httpService:JSONEncode(skillEntries)
					buildEvent:FireServer("LogicProp", selectionHandler:SendSelected(), "Dict", jsonEncoded)
				end)

			elseif inputType == 2 then
				-- Numeric text input
				local numOption = characterGui.Preset.OptionText:Clone()
				numOption.Option.Text = fieldName
				numOption.LayoutOrder = fieldOrder
				numOption.TextBox.Text = tostring(skillData[fieldName])
				numOption.Parent = characterEditorPanel.Timeline.Properties
				numOption.TextBox.FocusLost:Connect(function()
					skillData[fieldName] = tonumber(numOption.TextBox.Text)
					local btn = selectedButton
					btn.Text = "[" .. tostring(skillData.NAME) .. "] " .. skillTypeLabel
					local jsonEncoded = httpService:JSONEncode(skillEntries)
					buildEvent:FireServer("LogicProp", selectionHandler:SendSelected(), "Dict", jsonEncoded)
				end)

			elseif inputType == 3 then
				-- String text input
				local strOption = characterGui.Preset.OptionText:Clone()
				strOption.Option.Text = fieldName
				strOption.LayoutOrder = fieldOrder
				strOption.TextBox.Text = tostring(skillData[fieldName])
				strOption.Parent = characterEditorPanel.Timeline.Properties
				strOption.TextBox.FocusLost:Connect(function()
					skillData[fieldName] = tostring(strOption.TextBox.Text)
					local btn = selectedButton
					btn.Text = "[" .. tostring(skillData.NAME) .. "] " .. skillTypeLabel
					local jsonEncoded = httpService:JSONEncode(skillEntries)
					buildEvent:FireServer("LogicProp", selectionHandler:SendSelected(), "Dict", jsonEncoded)
				end)
				if fieldName == "VARIANT" then
					strOption.TextBox.PlaceholderText = "UP | DOWN"
				end

			elseif inputType == 4 then
				-- Button that opens the Builder skill editor
				local btnOption = characterGui.Preset.OptionButton:Clone()
				btnOption.Option.Text = fieldName
				btnOption.LayoutOrder = fieldOrder
				btnOption.Parent = characterEditorPanel.Timeline.Properties
				btnOption.TextButton.MouseButton1Down:Connect(function()
					characterEditorPanel.Visible = false
					characterEditorPanel.Parent.Builder.Visible = true
					require(script.Parent.Builder):updateKeys(skillData[fieldName], true)
				end)
			end
		end
	else
		-- No skill selected — show item list
		characterEditorPanel.Timeline.Properties.Visible = false
		characterEditorPanel.Timeline.Items.Visible = true
		characterEditorPanel.Toolbar.Visible = false
		characterEditorPanel.Toolbar2.Visible = true
		for _, button in characterEditorPanel.Timeline.Timeline:GetChildren() do
			if button:IsA("TextButton") then
				button.BorderColor3 = Color3.fromRGB(0, 0, 0)
			end
		end
	end
end

-- Creates a timeline button for a skill entry and wires up its click handler
local function addSkillTimelineButton(sourceButton, slotIndex)
	local newButton = sourceButton:Clone()
	newButton.LayoutOrder = slotIndex
	newButton.Size = UDim2.new(1, -5, 0.115, 0)
	newButton.Parent = characterEditorPanel.Timeline.Timeline

	local entry = skillEntries[slotIndex]
	local typeLabel = sourceButton.Text
	newButton.Text = "[" .. tostring(entry.NAME) .. "] " .. typeLabel

	local jsonEncoded = httpService:JSONEncode(skillEntries)
	buildEvent:FireServer("LogicProp", selectionHandler:SendSelected(), "Dict", jsonEncoded)

	newButton.MouseButton1Down:Connect(function()
		if selectedSkillIndex == newButton.LayoutOrder then
			selectedSkillIndex = nil
		else
			selectedSkillIndex = newButton.LayoutOrder
		end
		refreshPropertiesPanel()
	end)
end

-- Populate skill type buttons in the item list
for _, skillTypeButton in characterEditorPanel.Timeline.Items:GetChildren() do
	if skillTypeButton:IsA("TextButton") then
		skillTypeButton.MouseButton1Down:Connect(function()
			if skillFieldSchema[skillTypeButton.Name] then
				-- Find next available slot index
				local nextIndex = 1
				for _, _ in skillEntries do
					nextIndex = nextIndex + 1
				end
				selectedSkillIndex = nextIndex
				skillEntries[nextIndex] = {
					["K_NAME"] = skillTypeButton.Name
				}
				for _, fieldDef in skillFieldSchema[skillTypeButton.Name] do
					skillEntries[nextIndex][fieldDef[1]] = fieldDef[3]
				end
				addSkillTimelineButton(skillTypeButton, nextIndex)
				refreshPropertiesPanel()
				local jsonEncoded = httpService:JSONEncode(skillEntries)
				buildEvent:FireServer("LogicProp", selectionHandler:SendSelected(), "Dict", jsonEncoded)
			end
		end)
	end
end

-- Delete selected skill entry
characterEditorPanel.Toolbar.Kill.MouseButton1Down:Connect(function()
	if characterEditorPanel.Timeline.Visible == true then
		if not selectedSkillIndex then return end
		local button = getTimelineButtonByIndex()
		if not button then return end
		button:Destroy()
		skillEntries[selectedSkillIndex] = nil

		-- Compact indices downward to fill the gap
		for index, entry in skillEntries do
			local btn = getTimelineButtonByIndex(index)
			for compactIndex = index, 1, -1 do
				if not skillEntries[compactIndex] then
					skillEntries[compactIndex] = entry
					skillEntries[index] = nil
					btn.LayoutOrder = compactIndex
					break
				end
			end
		end

		refreshPropertiesPanel()
		local jsonEncoded = httpService:JSONEncode(skillEntries)
		buildEvent:FireServer("LogicProp", selectionHandler:SendSelected(), "Dict", jsonEncoded)
	end
end)

-- Move selected skill entry up in the list
characterEditorPanel.Toolbar.Up.MouseButton1Down:Connect(function()
	if characterEditorPanel.Timeline.Visible == true then
		if not selectedSkillIndex then return end
		local currentEntry = skillEntries[selectedSkillIndex]
		local entryAbove = skillEntries[selectedSkillIndex - 1]
		if not entryAbove then return end
		local currentButton = getTimelineButtonByIndex()
		local buttonAbove = getTimelineButtonByIndex(selectedSkillIndex - 1)
		if not (currentButton and buttonAbove) then return end
		skillEntries[selectedSkillIndex] = entryAbove
		skillEntries[selectedSkillIndex - 1] = currentEntry
		currentButton.LayoutOrder = selectedSkillIndex - 1
		buttonAbove.LayoutOrder = selectedSkillIndex
		selectedSkillIndex = selectedSkillIndex - 1
		refreshPropertiesPanel()
		local jsonEncoded = httpService:JSONEncode(skillEntries)
		buildEvent:FireServer("LogicProp", selectionHandler:SendSelected(), "Dict", jsonEncoded)
	end
end)

-- Move selected skill entry down in the list
characterEditorPanel.Toolbar.Down.MouseButton1Down:Connect(function()
	if characterEditorPanel.Timeline.Visible == true then
		if not selectedSkillIndex then return end
		local currentEntry = skillEntries[selectedSkillIndex]
		local entryBelow = skillEntries[selectedSkillIndex + 1]
		if not entryBelow then return end
		local currentButton = getTimelineButtonByIndex()
		local buttonBelow = getTimelineButtonByIndex(selectedSkillIndex + 1)
		if not (currentButton and buttonBelow) then return end
		skillEntries[selectedSkillIndex] = entryBelow
		skillEntries[selectedSkillIndex + 1] = currentEntry
		currentButton.LayoutOrder = selectedSkillIndex + 1
		buttonBelow.LayoutOrder = selectedSkillIndex
		selectedSkillIndex = selectedSkillIndex + 1
		refreshPropertiesPanel()
		local jsonEncoded = httpService:JSONEncode(skillEntries)
		buildEvent:FireServer("LogicProp", selectionHandler:SendSelected(), "Dict", jsonEncoded)
	end
end)

-- Duplicate selected skill entry and insert it after the current position
characterEditorPanel.Toolbar.Copy.MouseButton1Down:Connect(function()
	if characterEditorPanel.Timeline.Visible == true then
		if not selectedSkillIndex then return end
		local entryToCopy = skillEntries[selectedSkillIndex]
		local skillTypeItem = characterEditorPanel.Timeline.Items:FindFirstChild(entryToCopy.K_NAME)
		if not skillTypeItem then return end

		-- Count total entries
		local totalEntries = 0
		for _, _ in skillEntries do
			totalEntries = totalEntries + 1
		end

		-- Shift all entries after the selection down by one
		for shiftIndex = totalEntries, 1, -1 do
			if shiftIndex <= selectedSkillIndex then break end
			local shiftButton = getTimelineButtonByIndex(shiftIndex)
			skillEntries[shiftIndex + 1] = skillEntries[shiftIndex]
			skillEntries[shiftIndex] = nil
			shiftButton.LayoutOrder = shiftIndex + 1
		end

		-- Insert the duplicate at the next slot
		selectedSkillIndex = selectedSkillIndex + 1
		skillEntries[selectedSkillIndex] = deepClone(entryToCopy)
		addSkillTimelineButton(skillTypeItem, selectedSkillIndex)
		refreshPropertiesPanel()

		local jsonEncoded = httpService:JSONEncode(skillEntries)
		buildEvent:FireServer("LogicProp", selectionHandler:SendSelected(), "Dict", jsonEncoded)
	end
end)

-- Export box (shown when user clicks Export)
local exportTextBox = nil

characterEditorPanel.Toolbar2.Export.MouseButton1Down:Connect(function()
	if exportTextBox then
		exportTextBox:Destroy()
		exportTextBox = nil
	end
	exportTextBox = characterEditorPanel.Parent.Preset.TextBox:Clone()
