	local function selectAllText()
		exportTextBox.SelectionStart = 0
		exportTextBox.CursorPosition = #exportTextBox.Text + 1
	end
	exportTextBox.Focused:Connect(selectAllText)
	exportTextBox:GetPropertyChangedSignal("SelectionStart"):Connect(selectAllText)
	exportTextBox:GetPropertyChangedSignal("CursorPosition"):Connect(selectAllText)
	exportTextBox.SelectionStart = 0
	exportTextBox.CursorPosition = #exportTextBox.Text + 1

	exportTextBox.TextButton.MouseButton1Down:Connect(function()
		exportTextBox:Destroy()
		exportTextBox = nil
	end)
end)

characterEditorPanel.Toolbar2.Import.MouseButton1Down:Connect(function()
	if exportTextBox then
		exportTextBox:Destroy()
		exportTextBox = nil
	end
	exportTextBox = characterEditorPanel.Parent.Preset.TextBox:Clone()
	exportTextBox.Parent = characterEditorPanel

	exportTextBox.TextButton.MouseButton1Down:Connect(function()
		local success, err = pcall(function()
			local decoded = base64.from_base64(exportTextBox.Text)
			httpService:JSONDecode(decoded)
			CharacterEditor:updateKeys(decoded)
		end)
		if not success then
			warn(err)
		end
	end)
end)

function CharacterEditor.updateKeys(_, encodedData)
	if encodedData == nil then
		encodedData = {}
	else
		local success, err = pcall(function()
			encodedData = game:GetService("HttpService"):JSONDecode(encodedData)
		end)
		if not success then
			encodedData = {}
			warn(err)
		end
	end

	skillEntries = encodedData
	selectedSkillIndex = nil

	-- Clear existing timeline buttons
	for _, button in characterEditorPanel.Timeline.Timeline:GetChildren() do
		if button:IsA("TextButton") then
			button:Destroy()
		end
	end

	-- Remove any open export/import box
	if exportTextBox then
		exportTextBox:Destroy()
		exportTextBox = nil
	end

	-- Re-populate timeline from loaded data
	for slotIndex, entry in skillEntries do
		if skillFieldSchema[entry.K_NAME] then
			addSkillTimelineButton(characterEditorPanel.Timeline.Items[entry.K_NAME], slotIndex)
		end
	end

	refreshPropertiesPanel()
end

return CharacterEditor
